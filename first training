#设函数
def run_one_mask_experiment(expression, metadata, target_gene, n_mask=4, seed=0):
    """
    Run one masked gene expression prediction experiment.

    Parameters
    ----------
    expression:
        Original complete cell x gene expression matrix.

    metadata:
        Cell metadata table.

    target_gene:
        Gene to mask and predict, e.g. "TREM2".

    n_mask:
        Number of cells to mask.

    seed:
        Random seed for reproducibility.

    Returns
    -------
    comparison:
        A DataFrame containing MAE and MSE for each model.
    """

    # -------------------------
    # 1. Randomly choose masked cells
    # -------------------------
    rng = np.random.default_rng(seed)

    mask_cells = rng.choice(
        expression.index,
        size=n_mask,
        replace=False
    )

    # -------------------------
    # 2. Save ground truth before masking
    # -------------------------
    ground_truth = expression.loc[mask_cells, target_gene].copy()

    # -------------------------
    # 3. Create masked expression matrix
    # -------------------------
    expression_masked = expression.copy()
    expression_masked.loc[mask_cells, target_gene] = np.nan

    # -------------------------
    # 4. Define train/test cells
    # -------------------------
    train_cells = expression_masked.index[expression_masked[target_gene].notna()]
    test_cells = expression_masked.index[expression_masked[target_gene].isna()]

    y_train = expression_masked.loc[train_cells, target_gene]
    y_test = ground_truth.loc[test_cells]

    # -------------------------
    # 5. Feature genes
    # -------------------------
    feature_genes = [gene for gene in expression.columns if gene != target_gene]

    X_train_genes = expression_masked.loc[train_cells, feature_genes]
    X_test_genes = expression_masked.loc[test_cells, feature_genes]

    # ============================================================
    # Model 1: global mean baseline
    # ============================================================
    global_mean_prediction = expression_masked[target_gene].mean()

    global_predictions = pd.Series(
        global_mean_prediction,
        index=test_cells
    )

    global_mae = mean_absolute_error(y_test, global_predictions)
    global_mse = mean_squared_error(y_test, global_predictions)

    # ============================================================
    # Model 2: cell-type mean baseline
    # ============================================================
    celltype_predictions = []

    for cell_id in test_cells:
        cell_type = metadata.loc[cell_id, "cell_type"]

        same_type_cells = metadata.index[
            metadata["cell_type"] == cell_type
        ]

        available_values = expression_masked.loc[
            same_type_cells,
            target_gene
        ].dropna()

        if len(available_values) > 0:
            prediction = available_values.mean()
        else:
            prediction = global_mean_prediction

        celltype_predictions.append(prediction)

    celltype_predictions = pd.Series(
        celltype_predictions,
        index=test_cells
    )

    celltype_mae = mean_absolute_error(y_test, celltype_predictions)
    celltype_mse = mean_squared_error(y_test, celltype_predictions)

    # ============================================================
    # Model 3: disease + cell-type mean baseline
    # ============================================================
    disease_celltype_predictions = []

    for cell_id in test_cells:
        disease = metadata.loc[cell_id, "disease"]
        cell_type = metadata.loc[cell_id, "cell_type"]

        same_group_cells = metadata.index[
            (metadata["disease"] == disease) &
            (metadata["cell_type"] == cell_type)
        ]

        available_values = expression_masked.loc[
            same_group_cells,
            target_gene
        ].dropna()

        if len(available_values) > 0:
            prediction = available_values.mean()
        else:
            same_type_cells = metadata.index[
                metadata["cell_type"] == cell_type
            ]

            available_values = expression_masked.loc[
                same_type_cells,
                target_gene
            ].dropna()

            if len(available_values) > 0:
                prediction = available_values.mean()
            else:
                prediction = global_mean_prediction

        disease_celltype_predictions.append(prediction)

    disease_celltype_predictions = pd.Series(
        disease_celltype_predictions,
        index=test_cells
    )

    disease_celltype_mae = mean_absolute_error(y_test, disease_celltype_predictions)
    disease_celltype_mse = mean_squared_error(y_test, disease_celltype_predictions)

    # ============================================================
    # Model 4: Ridge regression, genes only
    # ============================================================
    ridge_gene_model = make_pipeline(
        StandardScaler(),
        Ridge(alpha=1.0)
    )

    ridge_gene_model.fit(X_train_genes, y_train)

    ridge_gene_predictions = ridge_gene_model.predict(X_test_genes)

    ridge_gene_mae = mean_absolute_error(y_test, ridge_gene_predictions)
    ridge_gene_mse = mean_squared_error(y_test, ridge_gene_predictions)

    # ============================================================
    # Model 5: Ridge regression, genes + metadata
    # ============================================================
    X_all = expression_masked[feature_genes].copy()
    X_all["disease"] = metadata["disease"]
    X_all["cell_type"] = metadata["cell_type"]

    X_train_meta = X_all.loc[train_cells]
    X_test_meta = X_all.loc[test_cells]

    numeric_features = feature_genes
    categorical_features = ["disease", "cell_type"]

    preprocess = ColumnTransformer(
        transformers=[
            ("genes", StandardScaler(), numeric_features),
            ("metadata", OneHotEncoder(handle_unknown="ignore"), categorical_features)
        ]
    )

    ridge_meta_model = Pipeline(
        steps=[
            ("preprocess", preprocess),
            ("ridge", Ridge(alpha=1.0))
        ]
    )

    ridge_meta_model.fit(X_train_meta, y_train)

    ridge_meta_predictions = ridge_meta_model.predict(X_test_meta)

    ridge_meta_mae = mean_absolute_error(y_test, ridge_meta_predictions)
    ridge_meta_mse = mean_squared_error(y_test, ridge_meta_predictions)

    # -------------------------
    # 6. Collect results
    # -------------------------
    comparison = pd.DataFrame({
        "model": [
            "global_mean",
            "celltype_mean",
            "disease_celltype_mean",
            "ridge_genes_only",
            "ridge_genes_metadata"
        ],
        "MAE": [
            global_mae,
            celltype_mae,
            disease_celltype_mae,
            ridge_gene_mae,
            ridge_meta_mae
        ],
        "MSE": [
            global_mse,
            celltype_mse,
            disease_celltype_mse,
            ridge_gene_mse,
            ridge_meta_mse
        ],
        "seed": seed
    })

    return comparison

