def predict_by_cell_type(cell_id):
    cell_type = metadata.loc[cell_id, "cell_type"]
    
    same_type_cells = metadata.index[metadata["cell_type"] == cell_type]
    
    available_values = expression_masked.loc[same_type_cells, target_gene].dropna()
    
    prediction = available_values.mean()
    
    return prediction


celltype_predictions = pd.Series(
    {cell_id: predict_by_cell_type(cell_id) for cell_id in mask_cells},
    name="celltype_mean_prediction"
)

