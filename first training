def run_one_mask_experiment_v4(
    expression,
    metadata,
    target_gene,
    feature_genes=None,
    mask_strategy="stratified",
    donor_col="donor",
    n_mask=4,
    seed=0,
    ridge_alpha=10.0,
    clip_predictions=True
):
    # -------------------------
    # 1. Choose masked cells
    # -------------------------
    if mask_strategy == "stratified":
        mask_cells = choose_stratified_mask_cells(
            metadata=metadata,
            n_mask=n_mask,
            seed=seed
        )
        split_info = "stratified"

    elif mask_strategy == "donor_heldout":
        mask_cells, selected_donor = choose_donor_heldout_mask_cells(
            metadata=metadata,
            donor_col=donor_col,
            seed=seed
        )
        split_info = f"donor_heldout:{selected_donor}"

    else:
        raise ValueError(
            "mask_strategy must be either 'stratified' or 'donor_heldout'."
        )

    # -------------------------
    # 2. Mask target gene
    # -------------------------
    ground_truth = expression.loc[mask_cells, target_gene].copy()

    expression_masked = expression.copy()
    expression_masked.loc[mask_cells, target_gene] = np.nan

    train_cells = expression_masked.index[
        expression_masked[target_gene].notna()
    ]

    test_cells = expression_masked.index[
        expression_masked[target_gene].isna()
    ]

    y_train = expression_masked.loc[train_cells, target_gene]
    y_test = ground_truth.loc[test_cells]

    # -------------------------
    # 3. Feature genes
    # -------------------------
    if feature_genes is None:
        candidate_genes = expression.columns
    else:
        candidate_genes = feature_genes

    feature_genes = [
        gene for gene in candidate_genes
        if gene != target_gene
    ]

    X_train_genes = expression_masked.loc[train_cells, feature_genes]
    X_test_genes = expression_masked.loc[test_cells, feature_genes]

    results = []

    # ============================================================
    # Model 1: global mean
    # ============================================================
    global_mean_prediction = expression_masked[target_gene].mean()

    global_predictions = pd.Series(
        global_mean_prediction,
        index=test_cells
    )

    results.append({
        "model": "global_mean",
        "MAE": mean_absolute_error(y_test, global_predictions),
        "MSE": mean_squared_error(y_test, global_predictions),
        "seed": seed,
        "n_features": len(feature_genes),
        "mask_strategy": mask_strategy,
        "split_info": split_info
    })

    # ============================================================
    # Model 2: cell-type mean
    # ============================================================
    celltype_predictions = []

    for cell_id in test_cells:
        cell_type = metadata.loc[cell_id, "cell_type"]

        same_type_cells = metadata.index[
            metadata["cell_type"] == cell_type
        ]

        available_values = expression_masked.loc[
            same_type_cells,
            target_gene
        ].dropna()

        if len(available_values) > 0:
            prediction = available_values.mean()
        else:
            prediction = global_mean_prediction

        celltype_predictions.append(prediction)

    celltype_predictions = pd.Series(
        celltype_predictions,
        index=test_cells
    )

    results.append({
        "model": "celltype_mean",
        "MAE": mean_absolute_error(y_test, celltype_predictions),
        "MSE": mean_squared_error(y_test, celltype_predictions),
        "seed": seed,
        "n_features": len(feature_genes),
        "mask_strategy": mask_strategy,
        "split_info": split_info
    })

    # ============================================================
    # Model 3: disease + cell-type mean
    # ============================================================
    disease_celltype_predictions = []

    for cell_id in test_cells:
        disease = metadata.loc[cell_id, "disease"]
        cell_type = metadata.loc[cell_id, "cell_type"]

        same_group_cells = metadata.index[
            (metadata["disease"] == disease) &
            (metadata["cell_type"] == cell_type)
        ]

        available_values = expression_masked.loc[
            same_group_cells,
            target_gene
        ].dropna()

        if len(available_values) > 0:
            prediction = available_values.mean()
        else:
            same_type_cells = metadata.index[
                metadata["cell_type"] == cell_type
            ]

            available_values = expression_masked.loc[
                same_type_cells,
                target_gene
            ].dropna()

            if len(available_values) > 0:
                prediction = available_values.mean()
            else:
                prediction = global_mean_prediction

        disease_celltype_predictions.append(prediction)

    disease_celltype_predictions = pd.Series(
        disease_celltype_predictions,
        index=test_cells
    )

    results.append({
        "model": "disease_celltype_mean",
        "MAE": mean_absolute_error(y_test, disease_celltype_predictions),
        "MSE": mean_squared_error(y_test, disease_celltype_predictions),
        "seed": seed,
        "n_features": len(feature_genes),
        "mask_strategy": mask_strategy,
        "split_info": split_info
    })

    # ============================================================
    # Model 4: Ridge genes only
    # ============================================================
    ridge_gene_model = make_pipeline(
        StandardScaler(),
        Ridge(alpha=ridge_alpha)
    )

    ridge_gene_model.fit(X_train_genes, y_train)

    ridge_gene_predictions = ridge_gene_model.predict(X_test_genes)

    if clip_predictions:
        ridge_gene_predictions = np.clip(ridge_gene_predictions, 0, None)

    results.append({
        "model": "ridge_genes_only",
        "MAE": mean_absolute_error(y_test, ridge_gene_predictions),
        "MSE": mean_squared_error(y_test, ridge_gene_predictions),
        "seed": seed,
        "n_features": len(feature_genes),
        "mask_strategy": mask_strategy,
        "split_info": split_info
    })

    # ============================================================
    # Model 5: Ridge genes + metadata
    # ============================================================
    X_all = expression_masked[feature_genes].copy()
    X_all["disease"] = metadata["disease"]
    X_all["cell_type"] = metadata["cell_type"]

    X_train_meta = X_all.loc[train_cells]
    X_test_meta = X_all.loc[test_cells]

    preprocess = ColumnTransformer(
        transformers=[
            ("genes", StandardScaler(), feature_genes),
            ("metadata", make_onehot_encoder(), ["disease", "cell_type"])
        ]
    )

    ridge_meta_model = Pipeline(
        steps=[
            ("preprocess", preprocess),
            ("ridge", Ridge(alpha=ridge_alpha))
        ]
    )

    ridge_meta_model.fit(X_train_meta, y_train)

    ridge_meta_predictions = ridge_meta_model.predict(X_test_meta)

    if clip_predictions:
        ridge_meta_predictions = np.clip(ridge_meta_predictions, 0, None)

    results.append({
        "model": "ridge_genes_metadata",
        "MAE": mean_absolute_error(y_test, ridge_meta_predictions),
        "MSE": mean_squared_error(y_test, ridge_meta_predictions),
        "seed": seed,
        "n_features": len(feature_genes),
        "mask_strategy": mask_strategy,
        "split_info": split_info
    })

    # ============================================================
    # Model 6: kNN genes only
    # ============================================================
    knn_gene_model = make_pipeline(
        StandardScaler(),
        KNeighborsRegressor(
            n_neighbors=3,
            weights="distance"
        )
    )

    knn_gene_model.fit(X_train_genes, y_train)

    knn_predictions = knn_gene_model.predict(X_test_genes)

    if clip_predictions:
        knn_predictions = np.clip(knn_predictions, 0, None)

    results.append({
        "model": "knn_genes_only",
        "MAE": mean_absolute_error(y_test, knn_predictions),
        "MSE": mean_squared_error(y_test, knn_predictions),
        "seed": seed,
        "n_features": len(feature_genes),
        "mask_strategy": mask_strategy,
        "split_info": split_info
    })

    return pd.DataFrame(results)







