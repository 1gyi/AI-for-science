def predict_by_disease_cell_type(cell_id):
    disease = metadata.loc[cell_id, "disease"]
    cell_type = metadata.loc[cell_id, "cell_type"]

    same_group_cells = metadata.index[
        (metadata["disease"] == disease) &
        (metadata["cell_type"] == cell_type)
    ]

    available_values = expression_masked.loc[same_group_cells, target_gene].dropna()

    if len(available_values) > 0:
        prediction = available_values.mean()
        method_used = "disease_celltype_mean"
    else:
        same_type_cells = metadata.index[
            metadata["cell_type"] == cell_type
        ]

        available_values = expression_masked.loc[same_type_cells, target_gene].dropna()

        if len(available_values) > 0:
            prediction = available_values.mean()
            method_used = "celltype_mean_fallback"
        else:
            prediction = expression_masked[target_gene].mean()
            method_used = "global_mean_fallback"
    return prediction, method_used
