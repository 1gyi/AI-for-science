def find_possible_obs_columns(adata):
    """
    Find possible disease, cell type, donor, batch columns in adata.obs.
    """

    obs_columns = list(adata.obs.columns)

    keywords = {
        "disease_or_condition": ["disease", "condition", "diagnosis", "status", "case_control"],
        "cell_type": ["cell_type", "celltype", "cell type", "annotation", "cluster", "subclass", "class"],
        "donor_or_sample": ["donor", "subject", "individual", "sample", "patient", "case"],
        "batch": ["batch", "library", "platform", "site", "study"]
    }

    matches = {}

    for category, words in keywords.items():
        matched_columns = []

        for col in obs_columns:
            col_lower = col.lower()

            for word in words:
                if word in col_lower:
                    matched_columns.append(col)
                    break

        matches[category] = matched_columns

    return matches

