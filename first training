def run_repeated_benchmark_from_adata_v2(
    adata,
    target_gene,
    layer=None,
    n_mask=4,
    n_repeats=30,
    ridge_alpha=10.0,
    clip_predictions=True
):
    """
    Run repeated masked gene expression benchmark from AnnData.

    If layer is None, use adata.X.
    If layer is a string, use adata.layers[layer].
    """

    expression_df, metadata_df = extract_tables_from_adata_v2(
        adata,
        layer=layer
    )

    if target_gene not in expression_df.columns:
        raise ValueError(
            f"{target_gene} is not found in adata.var_names."
        )

    all_results = []

    for seed in range(n_repeats):
        result = run_one_mask_experiment_v2(
            expression=expression_df,
            metadata=metadata_df,
            target_gene=target_gene,
            n_mask=n_mask,
            seed=seed,
            ridge_alpha=ridge_alpha,
            clip_predictions=clip_predictions
        )

        result["expression_source"] = "adata.X" if layer is None else layer

        all_results.append(result)

    all_results = pd.concat(
        all_results,
        ignore_index=True
    )

    summary = (
        all_results
        .groupby(["expression_source", "model"])
        .agg(
            mean_MAE=("MAE", "mean"),
            std_MAE=("MAE", "std"),
            mean_MSE=("MSE", "mean"),
            std_MSE=("MSE", "std")
        )
        .reset_index()
        .sort_values(["expression_source", "mean_MAE"])
    )

    return all_results, summary


