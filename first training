def choose_donor_heldout_mask_cells(metadata, donor_col="donor", seed=0):
    """
    Choose all cells from one donor as masked test cells.

    This creates a donor-held-out split:
    - test cells come from one donor
    - training cells come from all other donors
    """

    rng = np.random.default_rng(seed)

    donors = metadata[donor_col].unique()

    selected_donor = rng.choice(donors)

    mask_cells = metadata.index[
        metadata[donor_col] == selected_donor
    ].to_numpy()

    return mask_cells, selected_donor


