# =========================
# Cell 16: 导入机器学习工具
# =========================

from sklearn.linear_model import LinearRegression, Ridge
from sklearn.pipeline import make_pipeline
from sklearn.preprocessing import StandardScaler
from sklearn.metrics import mean_absolute_error, mean_squared_error

print("Machine learning tools loaded")、
# =========================
# Cell 17: 构建 feature genes
# =========================

feature_genes = [gene for gene in expression.columns if gene != target_gene]

print("Target gene:", target_gene)
print("Feature genes:", feature_genes)
# =========================
# Cell 18: 划分训练细胞和测试细胞
# =========================

train_cells = expression_masked.index[expression_masked[target_gene].notna()]
test_cells = expression_masked.index[expression_masked[target_gene].isna()]

print("Training cells:")
print(train_cells.tolist())

print("\nTest / masked cells:")
print(test_cells.tolist())
# =========================
# Cell 19: 构建 X_train, y_train, X_test, y_test
# =========================

X_train = expression_masked.loc[train_cells, feature_genes]
y_train = expression_masked.loc[train_cells, target_gene]

X_test = expression_masked.loc[test_cells, feature_genes]
y_test = ground_truth.loc[test_cells]

print("X_train shape:", X_train.shape)
print("y_train shape:", y_train.shape)
print("X_test shape:", X_test.shape)
print("y_test shape:", y_test.shape)
# =========================
# Cell 20: 训练 Linear Regression
# =========================

linear_model = LinearRegression()

linear_model.fit(X_train, y_train)

linear_predictions = linear_model.predict(X_test)

linear_results = pd.DataFrame({
    "disease": metadata.loc[test_cells, "disease"],
    "cell_type": metadata.loc[test_cells, "cell_type"],
    "true_TREM2": y_test,
    "predicted_TREM2": linear_predictions
}, index=test_cells)

linear_results["error"] = (
    linear_results["predicted_TREM2"] -
    linear_results["true_TREM2"]
)

linear_results["absolute_error"] = linear_results["error"].abs()

linear_results
# =========================
# Cell 21: 查看 Linear Regression 学到的 gene coefficients
# =========================

linear_coefficients = pd.Series(
    linear_model.coef_,
    index=feature_genes,
    name="linear_coefficient"
).sort_values(ascending=False)

linear_coefficients
# =========================
# Cell 22: 训练 Ridge Regression
# =========================

ridge_model = make_pipeline(
    StandardScaler(),
    Ridge(alpha=1.0)
)

ridge_model.fit(X_train, y_train)

ridge_predictions = ridge_model.predict(X_test)

ridge_results = pd.DataFrame({
    "disease": metadata.loc[test_cells, "disease"],
    "cell_type": metadata.loc[test_cells, "cell_type"],
    "true_TREM2": y_test,
    "predicted_TREM2": ridge_predictions
}, index=test_cells)

ridge_results["error"] = (
    ridge_results["predicted_TREM2"] -
    ridge_results["true_TREM2"]
)

ridge_results["absolute_error"] = ridge_results["error"].abs()

ridge_results
# =========================
# Cell 23: 计算 Linear 和 Ridge 的 MAE / MSE
# =========================

linear_mae = mean_absolute_error(y_test, linear_predictions)
linear_mse = mean_squared_error(y_test, linear_predictions)

ridge_mae = mean_absolute_error(y_test, ridge_predictions)
ridge_mse = mean_squared_error(y_test, ridge_predictions)

print("Linear Regression")
print("MAE:", linear_mae)
print("MSE:", linear_mse)

print("\nRidge Regression")
print("MAE:", ridge_mae)
print("MSE:", ridge_mse)
# =========================
# Cell 24: 比较所有模型
# =========================

comparison = pd.DataFrame({
