def find_possible_obs_columns(adata):
    obs_columns = list(adata.obs.columns)

    keywords = {
        "donor": [
            "donor", "subject", "individual",
            "participant", "case", "specimen"
        ],
        "region": [
            "region", "brain", "structure",
            "area", "lobe", "roi"
        ],
        "disease_or_pathology": [
            "disease", "diagnosis", "pathology",
            "braak", "cerad", "adnc", "cps",
            "cognitive", "condition", "status"
        ],
        "cell_type": [
            "cell_type", "celltype", "subclass",
            "supertype", "cluster", "annotation",
            "class", "type"
        ],
        "batch": [
            "batch", "library", "chemistry",
            "platform", "method", "technology",
            "lane"
        ]
    }

    rows = []

    for category, words in keywords.items():
        for col in obs_columns:
            col_lower = col.lower()

            for word in words:
                if word in col_lower:
                    rows.append({
                        "category": category,
                        "matched_keyword": word,
                        "obs_column": col
                    })
                    break

    return pd.DataFrame(rows)


