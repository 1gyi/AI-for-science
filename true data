# ============================================================
# Config
# ============================================================

ADATA_PATH = "SEA_AD_microglia_immune.h5ad"
COUNTS_LAYER = "UMIs"

DONOR_COL = "Donor ID"
REGION_COL = "Brain Region"
CELLTYPE_COL = "Supertype"
BRAAK_COL = "Braak"

PILOT_REGION = "MTG"

TARGET_PANEL_NAME = "complement_phagocytosis"

TARGET_GENES = [
    "C3", "C1QB", "MSR1", "C1QC", "VSIG4",
    "CTSS", "C1QA", "FCGR3A", "GRN", "FCER1G", "CD68"
]

N_HVG = 1000
N_PCS = 30
RIDGE_ALPHA = 10.0

MAX_TRAIN_CELLS = 8000
MAX_TEST_CELLS = 3000

RANDOM_SEED = 42

OUTDIR = "outputs_task3_complement_ridge"
os.makedirs(OUTDIR, exist_ok=True)


# ============================================================
# Helper functions
# ============================================================

def to_csr(X):
    if sp.issparse(X):
        return X.tocsr()
    return sp.csr_matrix(X)


def normalize_log1p_sparse(X_counts):
    """
    Normalize each cell to total 10,000 UMIs, then log1p.
    X_counts should be cells x genes sparse matrix.
    """
    X_counts = to_csr(X_counts).astype(float)

    total_counts = np.asarray(X_counts.sum(axis=1)).ravel()
    total_counts[total_counts == 0] = np.nan

    scale = 10000.0 / total_counts
    scale[np.isnan(scale)] = 0.0

    X_norm = X_counts.multiply(scale[:, None]).tocsr()
    X_norm.data = np.log1p(X_norm.data)

    return X_norm


def safe_spearman(x, y):
    df = pd.DataFrame({"x": x, "y": y}).dropna()

    if df.shape[0] < 3:
        return np.nan

    if df["x"].nunique() < 2 or df["y"].nunique() < 2:
        return np.nan

    return df["x"].rank().corr(df["y"].rank())


def braak_to_group(x):
    x = str(x)

    if "0" in x or "II" in x:
        return "low"
    if "III" in x or "IV" in x:
        return "mid"
    if "V" in x or "VI" in x:
        return "high"

    return "unknown"


# ============================================================
# 1. Read AnnData
# ============================================================

print("Reading h5ad...")
adata = ad.read_h5ad(ADATA_PATH, backed="r")

print(adata)
print("Cells:", adata.n_obs)
print("Genes:", adata.n_vars)


# ============================================================
# 2. Select MTG Micro-PVM cells
# ============================================================

obs = adata.obs.copy()

is_region = obs[REGION_COL].astype(str) == PILOT_REGION
is_micro_pvm = obs[CELLTYPE_COL].astype(str).str.startswith("Micro-PVM")

pilot_mask = is_region & is_micro_pvm
pilot_obs = obs.loc[pilot_mask].copy()

print("\nPilot subset:")
print("Cells:", pilot_obs.shape[0])
print("Donors:", pilot_obs[DONOR_COL].nunique())
print("Braak:")
print(pilot_obs[BRAAK_COL].value_counts(dropna=False).to_string())

pilot_obs.to_csv(
    os.path.join(OUTDIR, "pilot_obs_mtg_micro_pvm.csv")
)


# ============================================================
# 3. Donor-wise split
# ============================================================

donor_table = (
    pilot_obs[[DONOR_COL, BRAAK_COL]]
    .drop_duplicates(subset=[DONOR_COL])
    .copy()
)

donor_table["braak_group"] = donor_table[BRAAK_COL].apply(braak_to_group)

print("\nDonor Braak group counts:")
print(donor_table["braak_group"].value_counts().to_string())

train_donors, test_donors = train_test_split(
    donor_table[DONOR_COL],
    test_size=0.2,
    random_state=RANDOM_SEED,
    stratify=donor_table["braak_group"]
)

train_donors = set(train_donors)
test_donors = set(test_donors)

train_cells = pilot_obs.index[pilot_obs[DONOR_COL].isin(train_donors)].to_numpy()
test_cells = pilot_obs.index[pilot_obs[DONOR_COL].isin(test_donors)].to_numpy()

rng = np.random.default_rng(RANDOM_SEED)

if len(train_cells) > MAX_TRAIN_CELLS:
    train_cells = rng.choice(train_cells, size=MAX_TRAIN_CELLS, replace=False)

if len(test_cells) > MAX_TEST_CELLS:
    test_cells = rng.choice(test_cells, size=MAX_TEST_CELLS, replace=False)

selected_cells = np.concatenate([train_cells, test_cells])

split_labels = pd.Series(index=selected_cells, dtype="object")
split_labels.loc[train_cells] = "train"
split_labels.loc[test_cells] = "test"

print("\nSmoke-test split:")
print("Train cells:", len(train_cells))
print("Test cells:", len(test_cells))
print("Train donors:", len(train_donors))
print("Test donors:", len(test_donors))


# ============================================================
# 4. Load selected cells x all genes
# ============================================================

print("\nLoading selected cells x all genes...")

adata_small = adata[selected_cells, :].to_memory()

if COUNTS_LAYER in adata_small.layers.keys():
    X_counts = adata_small.layers[COUNTS_LAYER]
    print("Using layer:", COUNTS_LAYER)
else:
    X_counts = adata_small.X
    print("UMIs layer not found; using adata.X")

X_log = normalize_log1p_sparse(X_counts)

var_names = pd.Index(adata_small.var_names.astype(str))


# ============================================================
# 5. Remove target panel genes from input
# ============================================================

target_genes_present = [g for g in TARGET_GENES if g in var_names]
target_idx = [var_names.get_loc(g) for g in target_genes_present]

input_gene_mask = np.ones(len(var_names), dtype=bool)
input_gene_mask[target_idx] = False

print("\nTarget genes present:")
print(target_genes_present)

print("Number of input candidate genes after target removal:", input_gene_mask.sum())


# ============================================================
# 6. Select HVGs from target-removed input genes
# ============================================================

print("\nSelecting HVGs...")

X_input_candidates = X_log[:, input_gene_mask]

gene_means = np.asarray(X_input_candidates.mean(axis=0)).ravel()
gene_sq_means = np.asarray(X_input_candidates.multiply(X_input_candidates).mean(axis=0)).ravel()
gene_vars = gene_sq_means - gene_means ** 2

n_hvg = min(N_HVG, X_input_candidates.shape[1])

hvg_local_idx = np.argsort(gene_vars)[-n_hvg:]
hvg_local_idx = hvg_local_idx[np.argsort(gene_vars[hvg_local_idx])[::-1]]

candidate_gene_names = var_names[input_gene_mask]
hvg_genes = candidate_gene_names[hvg_local_idx].tolist()

pd.DataFrame({
    "gene": hvg_genes,
    "variance": gene_vars[hvg_local_idx]
}).to_csv(
