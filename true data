            "Spearman": safe_spearman(true, pred),
            "mean_true": np.mean(true),
            "mean_pred": np.mean(pred),
        })

    return pd.DataFrame(rows)


metrics = pd.concat([
    evaluate_model(Y_test, Y_pred_global, "global_mean", target_genes_present),
    evaluate_model(Y_test, Y_pred_braak, "braak_group_mean", target_genes_present),
    evaluate_model(Y_test, Y_pred_ridge, "ridge_pca", target_genes_present),
], ignore_index=True)

metrics_path = os.path.join(
    OUTDIR,
    "complement_panel_per_gene_metrics.csv"
