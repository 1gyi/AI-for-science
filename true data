def summarize_column_levels(obs, col, group_name, donor_col="Donor ID"):
    """
    Summarize a metadata column at both cell level and donor level.

    Cell-level count:
        how many cells/nuclei have each value.

    Donor-level count:
        how many donors have each value.
        This is important because donor-level variables are repeated
        across many cells.
    """

    rows = []

    if col not in obs.columns:
        return pd.DataFrame([{
            "group": group_name,
            "column": col,
            "level": "COLUMN_NOT_FOUND",
            "n_cells": pd.NA,
            "n_donors": pd.NA,
            "fraction_cells": pd.NA,
        }])

    cell_counts = obs[col].value_counts(dropna=False)

    for level, n_cells in cell_counts.items():
        level_mask = obs[col].astype(str) == str(level)

        if donor_col in obs.columns:
            n_donors = obs.loc[level_mask, donor_col].nunique()
        else:
            n_donors = pd.NA

        rows.append({
            "group": group_name,
            "column": col,
            "level": level,
            "n_cells": int(n_cells),
            "n_donors": n_donors,
            "fraction_cells": n_cells / obs.shape[0],
        })

    return pd.DataFrame(rows)


