import os
import numpy as np
import pandas as pd
import scipy.sparse as sp

target_qc_dir = "outputs_target_gene_qc"
os.makedirs(target_qc_dir, exist_ok=True)


# ----------------------------
# 1. Define pilot subset
# ----------------------------

DONOR_COL = "Donor ID"
REGION_COL = "Brain Region"
PATHOLOGY_COL = "Braak"
CELLTYPE_COL = "Supertype"
COUNTS_LAYER = "UMIs"

PILOT_REGION = "MTG"

is_micro_pvm = (
    adata.obs[CELLTYPE_COL]
    .astype(str)
    .str.startswith("Micro-PVM")
)

is_pilot_region = (
    adata.obs[REGION_COL]
    .astype(str)
    == PILOT_REGION
)

pilot_mask = is_micro_pvm & is_pilot_region
pilot_obs = adata.obs.loc[pilot_mask].copy()

print("\n===== Pilot subset for target gene QC =====")
print("Region:", PILOT_REGION)
print("Cells:", pilot_obs.shape[0])
print("Donors:", pilot_obs[DONOR_COL].nunique())

print("\nSupertype counts:")
print(pilot_obs[CELLTYPE_COL].value_counts(dropna=False).to_string())

print("\nBraak counts:")
print(pilot_obs[PATHOLOGY_COL].value_counts(dropna=False).to_string())


# ----------------------------
# 2. Define biological target panels
# ----------------------------

PANELS = {
    "homeostatic": [
        "P2RY12", "TMEM119", "CX3CR1", "SALL1", "GPR34",
        "OLFML3", "HEXB", "CSF1R", "MERTK", "SELPLG",
    ],

    "dam_activated": [
        "APOE", "TREM2", "TYROBP", "ITGAX", "LPL", "SPP1",
        "AXL", "CST7", "CD9", "CTSB", "CTSD", "LGALS3",
    ],

    "complement_phagocytosis": [
        "C1QA", "C1QB", "C1QC", "C3", "CTSS", "FCGR3A",
        "FCER1G", "MSR1", "VSIG4", "CD68", "GRN",
    ],
}

gene_to_panel = {}

for panel_name, genes in PANELS.items():
    for gene in genes:
        gene_to_panel[gene] = panel_name

candidate_target_genes = list(gene_to_panel.keys())


# ----------------------------
# 3. Check which target genes exist
# ----------------------------

var_names = pd.Index(adata.var_names.astype(str))

present_target_genes = [
    gene for gene in candidate_target_genes
    if gene in var_names
]

missing_target_genes = [
    gene for gene in candidate_target_genes
    if gene not in var_names
]

print("\n===== Target gene presence =====")
print("Candidate target genes:", len(candidate_target_genes))
print("Present target genes:", len(present_target_genes))
print("Missing target genes:", missing_target_genes)

gene_presence = pd.DataFrame({
    "panel": [gene_to_panel[gene] for gene in candidate_target_genes],
    "gene": candidate_target_genes,
    "present": [gene in present_target_genes for gene in candidate_target_genes],
})

gene_presence.to_csv(
    os.path.join(target_qc_dir, "sea_ad_panel_gene_presence.csv"),
    index=False
)


# ----------------------------
# 4. Load only pilot cells x target genes
# ----------------------------

print("\nLoading pilot cells x target genes...")

adata_target = adata[
    pilot_mask.values,
    present_target_genes
].to_memory()

if COUNTS_LAYER in adata_target.layers.keys():
    X_counts = adata_target.layers[COUNTS_LAYER]
    print("Using counts layer:", COUNTS_LAYER)
else:
    X_counts = adata_target.X
    print("Layer UMIs not found; using adata.X instead.")

if sp.issparse(X_counts):
    counts = X_counts.toarray()
else:
    counts = np.asarray(X_counts)

counts = counts.astype(float)

counts_df = pd.DataFrame(
    counts,
    index=adata_target.obs_names,
    columns=present_target_genes
)

print("Target count matrix shape:", counts_df.shape)


# ----------------------------
# 5. Normalize target genes for QC
# ----------------------------

cell_total_counts = counts_df.sum(axis=1)

# 注意：这里的 total counts 只基于 target genes，不是全基因 total UMIs。
# 所以 log_expr 主要用于 target gene QC 的相对比较。
# 正式建模时，我们会用全基因 UMIs 做 normalization。
log_counts = np.log1p(counts_df)


# ----------------------------
# 6. Compute target gene QC
# ----------------------------

qc_rows = []

for gene in present_target_genes:
    raw_values = counts_df[gene]
    log_values = log_counts[gene]

    detection_rate = (raw_values > 0).mean()
    n_expressing_cells = int((raw_values > 0).sum())

    donor_df = pd.DataFrame({
        DONOR_COL: adata_target.obs[DONOR_COL].values,
        "log_expr": log_values.values
    })

    donor_means = (
        donor_df
        .groupby(DONOR_COL)["log_expr"]
        .mean()
    )

    donor_mean_variance = donor_means.var()

    if detection_rate < 0.01:
        qc_decision = "drop"
        reason = "very low detection rate"
    elif detection_rate < 0.05:
        qc_decision = "maybe_drop"
        reason = "sparse target; inspect manually"
    elif log_values.var() < 1e-8:
        qc_decision = "maybe_drop"
        reason = "near-zero variance"
    else:
        qc_decision = "keep"
        reason = "passes basic detection and variance QC"

    qc_rows.append({
        "panel": gene_to_panel[gene],
        "gene": gene,
        "present": True,
        "n_cells": counts_df.shape[0],
        "n_expressing_cells": n_expressing_cells,
        "detection_rate": detection_rate,
        "mean_counts": raw_values.mean(),
        "var_counts": raw_values.var(),
        "mean_log1p_counts": log_values.mean(),
        "var_log1p_counts": log_values.var(),
        "donor_mean_variance": donor_mean_variance,
        "qc_decision": qc_decision,
        "reason": reason,
    })

