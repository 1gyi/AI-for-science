def list_s3_folders(bucket_name, prefix=""):
    """
    List immediate subfolders under an S3 prefix.
    """
    folders = []

    paginator = s3.get_paginator("list_objects_v2")

    for page in paginator.paginate(
        Bucket=bucket_name,
        Prefix=prefix,
        Delimiter="/"
    ):
        for item in page.get("CommonPrefixes", []):
            folders.append(item["Prefix"])

    return folders


def list_s3_objects(bucket_name, prefix="", max_items=100000):
    """
    List objects under an S3 prefix.
    """
    objects = []

    paginator = s3.get_paginator("list_objects_v2")

    for page in paginator.paginate(
        Bucket=bucket_name,
        Prefix=prefix,
        PaginationConfig={"MaxItems": max_items}
    ):
        for obj in page.get("Contents", []):
            objects.append({
                "key": obj["Key"],
                "size_GB": obj["Size"] / 1e9,
                "last_modified": obj["LastModified"]
            })

    return pd.DataFrame(objects)


