)

donor_table.to_csv(
    os.path.join(OUTDIR, "donor_split.csv"),
    index=False
)

train_cells_all = pilot_obs.index[pilot_obs[DONOR_COL].isin(train_donors)].astype(str).to_numpy()
test_cells_all = pilot_obs.index[pilot_obs[DONOR_COL].isin(test_donors)].astype(str).to_numpy()

rng = np.random.default_rng(RANDOM_SEED)

if MAX_TRAIN_CELLS is not None and len(train_cells_all) > MAX_TRAIN_CELLS:
    train_cells = rng.choice(train_cells_all, size=MAX_TRAIN_CELLS, replace=False)
else:
    train_cells = train_cells_all

if MAX_TEST_CELLS is not None and len(test_cells_all) > MAX_TEST_CELLS:
    test_cells = rng.choice(test_cells_all, size=MAX_TEST_CELLS, replace=False)
else:
    test_cells = test_cells_all

selected_cells = np.concatenate([train_cells, test_cells])

print("\nSmoke-test split:", flush=True)
print("Train donors:", len(train_donors), flush=True)
print("Test donors:", len(test_donors), flush=True)
print("Train cells before sampling:", len(train_cells_all), flush=True)
print("Test cells before sampling:", len(test_cells_all), flush=True)
print("Train cells used:", len(train_cells), flush=True)
print("Test cells used:", len(test_cells), flush=True)


# ============================================================
# 8. Load selected cells x all genes
# ============================================================

print("\nLoading selected cells x all genes...", flush=True)

adata_small = adata[selected_cells, :].to_memory()

if COUNTS_LAYER in adata_small.layers.keys():
    X_counts = adata_small.layers[COUNTS_LAYER]
    print("Using count layer:", COUNTS_LAYER, flush=True)
else:
    X_counts = adata_small.X
    print("Warning: UMIs layer not found. Using adata.X.", flush=True)

X_log = normalize_log1p_sparse(X_counts)

var_names = pd.Index(adata_small.var_names.astype(str))
cell_index = pd.Index(adata_small.obs_names.astype(str))

train_mask = cell_index.isin(train_cells)
test_mask = cell_index.isin(test_cells)

print("Loaded matrix shape:", X_log.shape, flush=True)
print("Train mask cells:", int(train_mask.sum()), flush=True)
print("Test mask cells:", int(test_mask.sum()), flush=True)


# ============================================================
# 9. Remove target panel genes from input
# ============================================================

print("\nRemoving target panel genes from input...", flush=True)

target_genes_present = [g for g in TARGET_GENES if g in var_names]
missing_target_genes = [g for g in TARGET_GENES if g not in var_names]

if len(target_genes_present) == 0:
    raise ValueError("None of the target genes were found in adata.var_names.")

target_idx = [var_names.get_loc(g) for g in target_genes_present]

input_gene_mask = np.ones(len(var_names), dtype=bool)
input_gene_mask[target_idx] = False

print("Target genes present:", target_genes_present, flush=True)
print("Target genes missing:", missing_target_genes, flush=True)
print("Input candidate genes after target removal:", int(input_gene_mask.sum()), flush=True)


# ============================================================
# 10. Select HVGs using TRAIN CELLS ONLY
# ============================================================

print("\nSelecting HVGs from train cells only...", flush=True)

X_input_candidates = X_log[:, input_gene_mask]
X_train_candidates = X_input_candidates[train_mask, :]

gene_means = np.asarray(X_train_candidates.mean(axis=0)).ravel()
gene_sq_means = np.asarray(
    X_train_candidates.multiply(X_train_candidates).mean(axis=0)
).ravel()

gene_vars = gene_sq_means - gene_means ** 2

n_hvg = min(N_HVG, X_train_candidates.shape[1])

hvg_local_idx = np.argsort(gene_vars)[-n_hvg:]
hvg_local_idx = hvg_local_idx[np.argsort(gene_vars[hvg_local_idx])[::-1]]

candidate_gene_names = var_names[input_gene_mask]
hvg_genes = candidate_gene_names[hvg_local_idx].tolist()

hvg_table = pd.DataFrame({
    "gene": hvg_genes,
    "train_variance": gene_vars[hvg_local_idx],
})

hvg_table.to_csv(
    os.path.join(OUTDIR, "selected_hvg_target_removed_train_only.csv"),
    index=False
)

print("Selected HVGs:", len(hvg_genes), flush=True)


# ============================================================
# 11. Build X and Y matrices
# ============================================================

print("\nBuilding X and Y matrices...", flush=True)

# X remains sparse
X_hvg = X_input_candidates[:, hvg_local_idx].tocsr()

# Y is small: target genes only, safe to make dense
Y_target = X_log[:, target_idx].toarray()

X_train = X_hvg[train_mask, :]
X_test = X_hvg[test_mask, :]

Y_train = Y_target[train_mask, :]
Y_test = Y_target[test_mask, :]

test_cell_ids = cell_index[test_mask]

print("X_train:", X_train.shape, flush=True)
print("X_test:", X_test.shape, flush=True)
print("Y_train:", Y_train.shape, flush=True)
print("Y_test:", Y_test.shape, flush=True)


# ============================================================
# 12. Sparse TruncatedSVD + Ridge
# ============================================================

print("\nTraining sparse TruncatedSVD + Ridge...", flush=True)

scaler = StandardScaler(with_mean=False)

X_train_scaled = scaler.fit_transform(X_train)
X_test_scaled = scaler.transform(X_test)

svd = TruncatedSVD(
    n_components=min(N_COMPONENTS, X_train_scaled.shape[1] - 1),
    random_state=RANDOM_SEED,
)

Z_train = svd.fit_transform(X_train_scaled)
Z_test = svd.transform(X_test_scaled)

print("SVD embedding train shape:", Z_train.shape, flush=True)
print("SVD embedding test shape:", Z_test.shape, flush=True)
print("SVD explained variance ratio sum:", float(svd.explained_variance_ratio_.sum()), flush=True)

ridge = Ridge(alpha=RIDGE_ALPHA)
ridge.fit(Z_train, Y_train)

Y_pred_svd_ridge = ridge.predict(Z_test)
Y_pred_svd_ridge = np.clip(Y_pred_svd_ridge, 0, None)

print("Finished SVD + Ridge.", flush=True)


# ============================================================
# 13. Baselines
# ============================================================

print("\nRunning baselines...", flush=True)

# Baseline 1: global mean
global_mean = Y_train.mean(axis=0)
Y_pred_global = np.tile(global_mean, (Y_test.shape[0], 1))

# Baseline 2: Braak group mean
train_obs_small = adata_small.obs.loc[cell_index[train_mask]].copy()
test_obs_small = adata_small.obs.loc[cell_index[test_mask]].copy()

train_obs_small[DONOR_COL] = train_obs_small[DONOR_COL].astype(str)
test_obs_small[DONOR_COL] = test_obs_small[DONOR_COL].astype(str)

train_obs_small["braak_group"] = train_obs_small[BRAAK_COL].apply(braak_to_group)
test_obs_small["braak_group"] = test_obs_small[BRAAK_COL].apply(braak_to_group)

Y_pred_braak = np.zeros_like(Y_test)

for i, group in enumerate(test_obs_small["braak_group"].values):
    train_group_mask = train_obs_small["braak_group"].values == group

    if train_group_mask.sum() > 0:
        Y_pred_braak[i, :] = Y_train[train_group_mask].mean(axis=0)
    else:
        Y_pred_braak[i, :] = global_mean


# ============================================================
# 14. Per-gene evaluation
# ============================================================

print("\nEvaluating per-gene metrics...", flush=True)

metrics = pd.concat(
    [
        evaluate_model(Y_test, Y_pred_global, "global_mean", target_genes_present),
        evaluate_model(Y_test, Y_pred_braak, "braak_group_mean", target_genes_present),
        evaluate_model(Y_test, Y_pred_svd_ridge, "svd_ridge", target_genes_present),
    ],
    ignore_index=True,
)

metrics_path = os.path.join(
    OUTDIR,
    "complement_panel_per_gene_metrics.csv"
)

metrics.to_csv(metrics_path, index=False)

print("\n===== Per-gene metrics =====", flush=True)
print(metrics.to_string(index=False), flush=True)
print("\nSaved per-gene metrics to:", metrics_path, flush=True)


# ============================================================
# 15. Panel score recovery
# ============================================================

print("\nEvaluating panel score recovery...", flush=True)

true_panel_score = Y_test.mean(axis=1)
pred_global_score = Y_pred_global.mean(axis=1)
pred_braak_score = Y_pred_braak.mean(axis=1)
pred_svd_ridge_score = Y_pred_svd_ridge.mean(axis=1)

panel_score_metrics = pd.DataFrame([
    {
        "model": "global_mean",
        "panel": TARGET_PANEL_NAME,
        "panel_score_spearman": safe_spearman(true_panel_score, pred_global_score),
        "panel_score_MAE": mean_absolute_error(true_panel_score, pred_global_score),
        "true_score_mean": float(np.mean(true_panel_score)),
        "pred_score_mean": float(np.mean(pred_global_score)),
    },
    {
        "model": "braak_group_mean",
        "panel": TARGET_PANEL_NAME,
        "panel_score_spearman": safe_spearman(true_panel_score, pred_braak_score),
        "panel_score_MAE": mean_absolute_error(true_panel_score, pred_braak_score),
        "true_score_mean": float(np.mean(true_panel_score)),
        "pred_score_mean": float(np.mean(pred_braak_score)),
    },
    {
        "model": "svd_ridge",
        "panel": TARGET_PANEL_NAME,
        "panel_score_spearman": safe_spearman(true_panel_score, pred_svd_ridge_score),
        "panel_score_MAE": mean_absolute_error(true_panel_score, pred_svd_ridge_score),
        "true_score_mean": float(np.mean(true_panel_score)),
        "pred_score_mean": float(np.mean(pred_svd_ridge_score)),
    },
])

panel_score_path = os.path.join(
    OUTDIR,
    "complement_panel_score_metrics.csv"
)

panel_score_metrics.to_csv(panel_score_path, index=False)

print("\n===== Panel score metrics =====", flush=True)
print(panel_score_metrics.to_string(index=False), flush=True)
print("\nSaved panel score metrics to:", panel_score_path, flush=True)


# ============================================================
# 16. Save test prediction table
# ============================================================

print("\nSaving prediction table...", flush=True)

prediction_table = pd.DataFrame({
    "cell_id": test_cell_ids,
    "true_panel_score": true_panel_score,
    "pred_global_score": pred_global_score,
    "pred_braak_score": pred_braak_score,
    "pred_svd_ridge_score": pred_svd_ridge_score,
    "donor": test_obs_small[DONOR_COL].values,
    "braak": test_obs_small[BRAAK_COL].values,
    "braak_group": test_obs_small["braak_group"].values,
    "supertype": test_obs_small[CELLTYPE_COL].values,
})

prediction_path = os.path.join(
    OUTDIR,
    "complement_panel_test_predictions.csv"
)

prediction_table.to_csv(
    prediction_path,
    index=False
)

print("Saved prediction table to:", prediction_path, flush=True)


# ============================================================
# 17. Done
# ============================================================

print("\nDone.", flush=True)











